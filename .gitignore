# ============================================================
# Default: ignore everything
# ============================================================
*

# ============================================================
# Keep Git config files
# ============================================================
!.gitignore

# ============================================================
# Keep GitHub workflow
# ============================================================
!.github/
!.github/**

# ============================================================
# Keep main project files
# ============================================================
!README.md
!requirements.txt
!pyproject.toml
!setup.py
!setup.cfg
!MANIFEST.in

!train_soundstream.py
!infer_soundstream.py
!install_fairseq.cmd
!run_stages_0_to_4.sh
!soundstream_training_network_summary.md

# ============================================================
# Keep source code directories
# ============================================================
!audiolm_pytorch/
!audiolm_pytorch/**

!configs/
!configs/**

!scripts/
!scripts/**

!docs/
!docs/**

# ============================================================
# Explicitly ignore generated / temporary garbage
# ============================================================
.runtime-tmp/
.torch-tmp/
.codex-presentations/
node_modules/
tmp/
temp/
.cache/
.cache*/

%SystemDrive%/
ProgramData/
Windows/Caches/

# ============================================================
# Explicitly ignore vendored embedded git repos
# ============================================================
.vendor/
vendor/

# ============================================================
# Python cache
# ============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/
.conda/
conda/

# ============================================================
# IDE
# ============================================================
.vscode/
.idea/

# ============================================================
# Logs
# ============================================================
logs/
*.log

# ============================================================
# Training outputs
# ============================================================
results/
outputs/
runs/
wandb/
tensorboard/
lightning_logs/
experiments/
checkpoints/
checkpoint/
ckpts/

# ============================================================
# Model weights
# ============================================================
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.onnx
*.engine

# ============================================================
# Audio / datasets / large data
# ============================================================
data/
dataset/
datasets/
corpus/
corpora/

*.wav
*.flac
*.mp3
*.m4a
*.aac
*.ogg

*.npy
*.npz
*.pkl
*.pickle
*.h5
*.hdf5
*.lmdb

*.tar
*.tar.gz
*.zip
*.rar
*.7z

# ============================================================
# Database / cache
# ============================================================
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ============================================================
# Secrets
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db
desktop.ini